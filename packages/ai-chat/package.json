{
  "name": "intelliui-ai-chat",
  "version": "0.1.8",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "description": "Adaptive AI chat runtime for React. Connect any backend route and embed AI chat anywhere in your application.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RanaHeet24/intelliui-npm-package.git",
    "directory": "packages/ai-chat"
  },
  "homepage": "https://intelliui.vercel.app/",
  "bugs": {
    "url": "https://github.com/RanaHeet24/intelliui-npm-package/issues"
  },
  "keywords": [
    "ai",
    "react",
    "chat",
    "llm",
    "assistant",
    "ai-chat",
    "ai-runtime",
    "openai",
    "gemini",
    "claude",
    "streaming",
    "typescript",
    "widget",
    "sidebar",
    "drawer",
    "embedded-ai",
    "react-chat",
    "headless-chat",
    "chat-ui",
    "adaptive-ui"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup && tailwindcss -i src/styles/index.css -o dist/styles.css --minify"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@types/react-dom": "^18.2.0 || ^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  }
}
